{
    "name": "twoquakers/peanut-core",
    "description": "Reference Application for Peanut Framework",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "license": "GPL-3.0+",
    "authors": [
        {
            "name": "Terry SoRelle",
            "email": "twoquakedev@outlook.com"
        }
    ],
    "require": {
        "phpunit/phpunit": "*",
        "smalot/pdfparser": "*",
        "ext-pdo": "*",
        "phpmailer/phpmailer": "*",
        "ext-json": "*",
        "soundasleep/html2text": "*",
        "ext-openssl": "*",
        "mailgun/mailgun-php": "*",
        "symfony/http-client": "*",
        "nyholm/psr7": "*",
      "ext-calendar": "*",
      "ext-dom": "*",
        "ext-simplexml": "*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "require-dev": {
        "phpcompatibility/php-compatibility": "^9.3"
    },
    "autoload": {
        "psr-4": {
            "Tops\\": "web.root/tq-peanut/src/tops/",
            "Peanut\\": "web.root/tq-peanut/src/peanut/",
            "Application\\": "web.root/tq-peanut/application/src/",
            "PeanutTest\\": "web.root/tq-peanut/src/test/"
        }
    }
}
